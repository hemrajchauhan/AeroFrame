<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>baad1c0a-1828-459a-bd15-ee7d556015b9</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>AeroFrame.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>AeroFrame</Name>
    <RootNamespace>AeroFrame</RootNamespace>
    <InterpreterId>MSBuild|venv|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="AeroFrame.py" />
    <Compile Include="core\models.py" />
    <Compile Include="core\pipeline.py" />
    <Compile Include="geometry\tigl_geometry.py" />
    <Compile Include="interfaces\cpacs.py" />
    <Compile Include="modules\aerodynamics.py" />
    <Compile Include="modules\performance.py" />
    <Compile Include="modules\weight.py" />
    <Compile Include="utils\environment.py" />
    <Compile Include="utils\numerics.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="core\" />
    <Folder Include="interfaces\" />
    <Folder Include="geometry\" />
    <Folder Include="modules\" />
    <Folder Include="data\" />
    <Folder Include="tests\" />
    <Folder Include="utils\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="venv\">
      <Id>venv</Id>
      <Version>3.14</Version>
      <Description>venv (Python 3.14 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
  <!-- Uncomment the CoreCompile target to enable the Build command in
       Visual Studio and specify your pre- and post-build commands in
       the BeforeBuild and AfterBuild targets below. -->
  <!--<Target Name="CoreCompile" />-->
  <Target Name="BeforeBuild">
  </Target>
  <Target Name="AfterBuild">
  </Target>
</Project>